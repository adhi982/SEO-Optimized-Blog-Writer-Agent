# ─────────────────────────────────────────
# LLM API Keys
# ─────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here

# ─────────────────────────────────────────
# Search API
# ─────────────────────────────────────────
SERPAPI_KEY=your_serpapi_key_here

# ─────────────────────────────────────────
# LLM Defaults (optional overrides)
# ─────────────────────────────────────────
RESEARCH_LLM_PROVIDER=gemini
RESEARCH_LLM_MODEL=gemini-2.0-flash

WRITING_LLM_PROVIDER=mistral
WRITING_LLM_MODEL=mistral-large-latest

QA_LLM_PROVIDER=groq
QA_LLM_MODEL=llama-3.3-70b-versatile

# ─────────────────────────────────────────
# Output
# ─────────────────────────────────────────
OUTPUT_DIR=output
